{
  "name": "scheduler-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "pnpm monorepo for the collaborative scheduler (Angular frontend + NestJS backend)",
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start:frontend": "pnpm --filter @scheduler/frontend start",
    "start:backend": "pnpm --filter @scheduler/backend start:dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter @scheduler/frontend build",
    "build:backend": "pnpm --filter @scheduler/backend build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  }
}
