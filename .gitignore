# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.
# Consolidated for the pnpm monorepo — patterns without a leading "/" match at any depth (root, apps/frontend, apps/backend).

# Dependencies
node_modules/
.pnpm-store/

# Build output (Angular + Nest)
dist/
build/
/tmp
out-tsc/
/bazel-out
*.tsbuildinfo

# Angular cache (any depth — pattern without an internal slash matches in apps/frontend too)
.angular/

# Tests & coverage
coverage/
.nyc_output/
testem.log
/libpeerconnection.log

# Logs
logs/
*.log
npm-debug.log
yarn-error.log

# Environment (never commit secrets) — keep examples
.env
.env.*
!.env.example

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/*

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Miscellaneous
.sass-cache/
/connect.lock
/typings

# System files
.DS_Store
Thumbs.db
