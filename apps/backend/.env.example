PORT=3100
# Matches the docker-compose Postgres (user/password: postgres/postgres).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scheduler
JWT_SECRET=replace-with-a-long-random-dev-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3100/api/auth/google/callback
FRONTEND_URL=http://localhost:4200
AUTH_TEST_MODE=true
